# Copy this to .env.local and fill in real values. Never commit .env.local.

APP_SECRET=generate_with_openssl_rand_hex_16

# MySQL passwords
MYSQL_ROOT_PASSWORD=choose_a_strong_root_password
MYSQL_PASSWORD=choose_a_strong_app_password

# Update DATABASE_URL if different from docker-compose default
DATABASE_URL="mysql://app:your_password@mysql:3306/house_visits?serverVersion=8.0&charset=utf8mb4"

# Google Sheets — place your key file in secrets/ and set the path here
GOOGLE_SERVICE_ACCOUNT_PATH=/var/www/html/secrets/google-sa-key.json
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_SHEET_RANGE=Sheet1!A2:E
