<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}House Visit Charts{% endblock %}</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: { 500: '#6366f1', 600: '#4f46e5', 700: '#4338ca' }
                    }
                }
            }
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>

    {% block head %}{% endblock %}
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen">

    {% if app.user %}
    <nav class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-3 flex items-center justify-between sticky top-0 z-10">
        <a href="{{ path('app_dashboard') }}" class="text-lg font-bold tracking-tight text-indigo-500">
            House Management System
        </a>
        <div class="flex items-center gap-4 text-sm">

            {# Reminder clock indicator #}
            <div class="relative" id="reminder-bell">
                <button onclick="toggleReminderDropdown()"
                    class="relative p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                    title="{{ active_reminder_count }} active reminder(s)">
                    <svg class="w-5 h-5 {{ overdue_reminder_count > 0 ? 'text-red-500' : 'text-gray-400 dark:text-gray-500' }}"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {% if active_reminder_count > 0 %}
                    <span class="absolute -top-1 -right-1 text-[10px] font-bold leading-none px-1 py-0.5 rounded-full
                        {{ overdue_reminder_count > 0 ? 'bg-red-500 text-white' : 'bg-indigo-500 text-white' }}">
                        {{ active_reminder_count }}
                    </span>
                    {% endif %}
                </button>

                {# Dropdown #}
                <div id="reminder-dropdown"
                     class="hidden absolute right-0 top-full mt-2 w-80 bg-white dark:bg-gray-800
                            border border-gray-200 dark:border-gray-700 rounded-xl shadow-xl z-50 p-3">
                    <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 mb-2 px-1">Active Reminders</p>
                    {% if active_reminders_preview|length == 0 %}
                    <p class="text-xs text-gray-500 px-1 py-2">No active reminders.</p>
                    {% else %}
                    <div class="space-y-1">
                        {% for r in active_reminders_preview %}
                        <a href="{{ path('app_avatar', {key: r.avatarKey}) }}#reminders"
                           onclick="document.getElementById('reminder-dropdown').classList.add('hidden')"
                           class="block text-xs p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                            <div class="font-medium text-gray-800 dark:text-gray-200 truncate">
                                {{ r.content|striptags|slice(0, 80) }}{% if r.content|length > 80 %}…{% endif %}
                            </div>
                            <div class="text-gray-400 mt-0.5 flex items-center gap-1">
                                <time datetime="{{ r.reminderAt|date('Y-m-d\\TH:i:s\\Z') }}"
                                      data-local
                                      class="{{ r.overdue ? 'text-red-400' : '' }}">
                                    {{ r.reminderAt|date('Y-m-d H:i') }} UTC
                                </time>
                                <span>&bull;</span>
                                <span>{{ r.author.username }}</span>
                            </div>
                        </a>
                        {% endfor %}
                        {% if active_reminder_count > 5 %}
                        <p class="text-xs text-gray-400 text-center pt-1 pb-0.5">
                            + {{ active_reminder_count - 5 }} more
                        </p>
                        {% endif %}
                    </div>
                    {% endif %}
                </div>
            </div>

            <span class="text-gray-500 dark:text-gray-400">{{ app.user.userIdentifier }}</span>
            <a href="{{ path('app_logout') }}" class="text-gray-500 hover:text-red-400 transition-colors">Logout</a>
        </div>
    </nav>
    {% endif %}

    <main class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        {% block body %}{% endblock %}
    </main>

    <script type="module" src="/assets/local-time.js"></script>
    <script>
    function toggleReminderDropdown() {
        document.getElementById('reminder-dropdown')?.classList.toggle('hidden');
    }
    document.addEventListener('click', function(e) {
        if (!e.target.closest('#reminder-bell')) {
            document.getElementById('reminder-dropdown')?.classList.add('hidden');
        }
    });
    </script>
    {% block scripts %}{% endblock %}
</body>
</html>
